{
  "expo": {
    "name": "Skull King Scorekeeper",
    "slug": "skull-king-scorekeeper",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "skullking",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b1722"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gabrielcretin.skullking",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.gabrielcretin.skullking",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b1722"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "f7a67ac9-2430-4901-86b7-262bc897ddb5"
      }
    }
  }
}
