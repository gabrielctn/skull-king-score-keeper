{
  "name": "skull-king-scorekeeper",
  "version": "1.1.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --web",
    "web": "expo start --web",
    "build:web": "expo export -p web && node scripts/build-pwa.mjs",
    "serve:web": "npx serve dist -l 8080",
    "test": "npm run typecheck && npm run test:scoring && npm run test:storage && npm run test:backup && npm run test:responsive && npm run test:assets && npm run test:branding",
    "typecheck": "tsc --noEmit",
    "test:scoring": "node --import tsx scripts/test-scoring.ts",
    "test:storage": "node --import tsx scripts/test-storage.ts",
    "test:backup": "node --import tsx scripts/test-backup.ts",
    "test:responsive": "node --import tsx scripts/test-responsive-layout.ts",
    "test:assets": "node --import tsx scripts/test-assets.ts",
    "test:branding": "node --import tsx scripts/test-branding.ts"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.35",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.11",
    "tsx": "^4.19.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
